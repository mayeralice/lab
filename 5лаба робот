  #include <stdio.h>
  #include <stdlib.h>
  #include <string.h>
  #include <unistd.h>
  #include <fcntl.h>
  #include <sys/ioctl.h>
  #include <linux/gpio.h>
  
  void gpio_write(int offset, int value) {
      int fd = open("/dev/gpiochip0", O_RDONLY);
      if (fd < 0) return;
      struct gpiohandle_request rq = {0};
      struct gpiohandle_data data = {0};
      rq.lineoffsets[0] = offset;
      rq.flags = GPIOHANDLE_REQUEST_OUTPUT;
      rq.lines = 1;
      ioctl(fd, GPIO_GET_LINEHANDLE_IOCTL, &rq);
      close(fd);
      data.values[0] = value;
      ioctl(rq.fd, GPIOHANDLE_SET_LINE_VALUES_IOCTL, &data);
      close(rq.fd);
  }
  
  void forward() {
      gpio_write(12, 1); gpio_write(13, 0);
      gpio_write(20, 1); gpio_write(21, 0);
  }
  
  void left() {
      gpio_write(12, 0); gpio_write(13, 0);
      gpio_write(20, 1); gpio_write(21, 0);
  }
  
  void right() {
      gpio_write(12, 1); gpio_write(13, 0);
      gpio_write(20, 0); gpio_write(21, 0);
  }
  
  void stop() {
      gpio_write(12, 0); gpio_write(13, 0);
      gpio_write(20, 0); gpio_write(21, 0);
  }
  
  int main(int argc, char* argv[]) {
      gpio_write(6, 1);
      gpio_write(26, 1);
      
      if (argc < 2) return 1;
      int ms = (argc >= 3) ? atoi(argv[2]) : 1000;
      
      if (strcmp(argv[1], "forward") == 0) { forward(); usleep(ms * 1000); stop(); }
      else if (strcmp(argv[1], "left") == 0) { left(); usleep(ms * 1000); stop(); }
      else if (strcmp(argv[1], "right") == 0) { right(); usleep(ms * 1000); stop(); }
      else if (strcmp(argv[1], "stop") == 0) { stop(); }
      
      return 0;
  }
